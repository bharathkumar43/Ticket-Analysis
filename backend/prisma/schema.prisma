generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PersonRole {
  MANAGER
  ENGINEER
  BOTH
}

enum DelayStatus {
  NOT_DELAYED
  DELAYED
  AT_RISK
  UNKNOWN
}

enum BreachFlag {
  YES
  NO
  UNKNOWN
}

model User {
  id             String   @id @default(cuid())
  username       String   @unique
  passwordHash   String
  email          String?
  msRefreshToken String?
  createdAt      DateTime @default(now())
}

model Person {
  id               String            @id @default(cuid())
  fullName         String
  role             PersonRole        @default(ENGINEER)
  aliases          PersonAlias[]
  managedProjects  Project[]         @relation("ProjectManager")
  accountProjects  Project[]         @relation("AccountManager")
  ticketsAsPM      Ticket[]          @relation("TicketPM")
  ticketsAssigned  Ticket[]          @relation("TicketAssignee")
  reportsTo        EngineerManager[] @relation("Engineer")
  manages          EngineerManager[] @relation("Manager")
  createdAt        DateTime          @default(now())

  @@index([fullName])
  @@index([role])
}

model PersonAlias {
  id       String @id @default(cuid())
  raw      String @unique
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  personId String

  @@index([raw])
}

model Customer {
  id            String          @id @default(cuid())
  canonical     String          @unique
  aliases       CustomerAlias[]
  projects      Project[]
  tickets       Ticket[]
  isPlaceholder Boolean         @default(false)

  @@index([canonical])
}

model CustomerAlias {
  id         String   @id @default(cuid())
  raw        String   @unique
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId String

  @@index([raw])
}

model Project {
  id               String      @id @default(cuid())
  name             String
  customer         Customer?   @relation(fields: [customerId], references: [id])
  customerId       String?
  manager          Person?     @relation("ProjectManager", fields: [managerId], references: [id])
  managerId        String?
  accountManager   Person?     @relation("AccountManager", fields: [accountManagerId], references: [id])
  accountManagerId String?
  migrationTypes   String?
  planType         String?
  status           String?
  phase            String?
  durationMonths   Float?
  expectedEnd      DateTime?
  extendedEnd      DateTime?
  delayStatus      DelayStatus @default(UNKNOWN)
  delayDays        Int?
  isOveraged       Boolean     @default(false)
  overageAmount    Float?
  sowStart         DateTime?
  sowEnd           DateTime?
  kickoffStart     DateTime?
  projectEnd       DateTime?
  lifecycle        String      @default("ACTIVE")
  createdAt        DateTime    @default(now())

  @@index([managerId])
  @@index([customerId])
  @@index([lifecycle])
  @@index([delayStatus])
}

model Ticket {
  id                  String     @id @default(cuid())
  jiraKey             String     @unique
  issueType           String?
  summary             String?
  assignee            Person?    @relation("TicketAssignee", fields: [assigneeId], references: [id])
  assigneeId          String?
  reporter            String?
  components          String?
  combination         String?
  priority            String?
  status              String?
  resolution          String?
  created             DateTime?
  updated             DateTime?
  dueDate             DateTime?
  firstResponseBreach BreachFlag @default(UNKNOWN)
  resolutionBreach    BreachFlag @default(UNKNOWN)
  customer            Customer?  @relation(fields: [customerId], references: [id])
  customerId          String?
  projectManager      Person?    @relation("TicketPM", fields: [projectManagerId], references: [id])
  projectManagerId    String?
  rootCause           String?
  resolutionHours     Float?
  syncRunId           String?

  @@index([priority])
  @@index([status])
  @@index([resolutionBreach])
  @@index([firstResponseBreach])
  @@index([customerId])
  @@index([projectManagerId])
  @@index([assigneeId])
  @@index([created])
  @@index([updated])
}

model EngineerManager {
  id         String @id @default(cuid())
  engineer   Person @relation("Engineer", fields: [engineerId], references: [id], onDelete: Cascade)
  engineerId String
  manager    Person @relation("Manager", fields: [managerId], references: [id], onDelete: Cascade)
  managerId  String

  @@unique([engineerId, managerId])
}

model RootCauseRule {
  id       String   @id @default(cuid())
  bucket   String
  keywords String[]
  priority Int      @default(100)

  @@index([priority])
}

model JiraSyncRun {
  id         String    @id @default(cuid())
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  jql        String
  fetched    Int       @default(0)
  upserted   Int       @default(0)
  status     String    @default("RUNNING")
  error      String?
}

model MonthlyUpload {
  id         String       @id @default(cuid())
  month      Int
  year       Int
  uploadType String
  fileName   String
  rowCount   Int          @default(0)
  uploadedBy String?
  uploadedAt DateTime     @default(now())
  rows       MonthlyRow[]

  @@unique([month, year, uploadType])
  @@index([year, month])
  @@index([uploadType])
}

model MonthlyRow {
  id         String        @id @default(cuid())
  upload     MonthlyUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  uploadId   String
  data       Json
  jiraKey    String?
  summary    String?
  assignee   String?
  status     String?
  priority   String?
  resolution String?
  created    DateTime?
  updated    DateTime?

  @@index([uploadId])
  @@index([status])
  @@index([assignee])
}

model ActionItem {
  id                 String    @id @default(cuid())
  seq                Int       @default(autoincrement())
  title              String
  meetingType        String    @default("MBR")
  owner              String?
  ownerEmail         String?
  priority           String    @default("Medium")
  dueDate            DateTime?
  status             String    @default("Open")
  notes              String?
  lastReminderSentAt DateTime?
  lastReminderKind   String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([status])
  @@index([meetingType])
  @@index([dueDate])
}
