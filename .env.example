# ─────────────────────────────────────────────────────────────────────────────
# MigrationOps Dashboard — Docker deployment environment variables
# Copy this file to .env and fill in your values, then run:
#   docker compose up -d --build
# ─────────────────────────────────────────────────────────────────────────────

# ── Public URL ────────────────────────────────────────────────────────────────
# The URL where users open the app (no trailing slash).
# Local:      PUBLIC_URL=http://localhost:8080
# Server:     PUBLIC_URL=http://192.168.1.100:8080
# Production: PUBLIC_URL=https://migrationops.yourdomain.com
#
# After changing this you MUST also update the Azure AD redirect URI to:
#   {PUBLIC_URL}/api/auth/microsoft/callback
PUBLIC_URL=https://opsauditing.cftools.live

# Port for the frontend Docker container (internal; system nginx proxies :80 to this).
# Do NOT change this unless you know what you're doing.
FRONTEND_PORT=6100

# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=migrationops
DB_PASSWORD=change-me-strong-password
DB_NAME=migrationops

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a random string: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-64-char-secret

# ── Microsoft Azure AD login (optional) ──────────────────────────────────────
# Register an app at https://portal.azure.com → Azure AD → App registrations
# Redirect URI to register (Web type):  {PUBLIC_URL}/api/auth/microsoft/callback
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# ── Neutara Ticketing (internal tool — Jira-compatible API) ──────────────────
NEUTARA_BASE_URL=https://neutaraticketing.cftools.live
NEUTARA_API_KEY=nta_your_api_key_here
# NEUTARA_EMAIL falls back to JIRA_EMAIL if not set

# ── Jira live sync (optional) ─────────────────────────────────────────────────
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@yourcompany.com
JIRA_API_TOKEN=
JIRA_JQL=project in (PROJ1, PROJ2) ORDER BY updated DESC
SYNC_CRON=0 */6 * * *

# ── Action Item reminder emails ───────────────────────────────────────────────
# Sent via Microsoft Graph API using the logged-in user's Microsoft account.
# No SMTP setup needed — just make sure AZURE_CLIENT_ID/SECRET above are set
# and at least one user has logged in with Microsoft.
ACTION_ITEM_REMINDER_CRON=0 8 * * *
