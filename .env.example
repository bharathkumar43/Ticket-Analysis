# ─────────────────────────────────────────────────────────────────────────────
# MigrationOps Dashboard — Docker deployment environment variables
# Copy this file to .env and fill in your values, then run:
#   docker compose up -d --build
# ─────────────────────────────────────────────────────────────────────────────

# ── Public URL ────────────────────────────────────────────────────────────────
# The URL where users open the app (no trailing slash).
# Local:      PUBLIC_URL=http://localhost
# Server:     PUBLIC_URL=http://192.168.1.100
# Production: PUBLIC_URL=https://migrationops.yourdomain.com
#
# After changing this you MUST also update the Azure AD redirect URI to:
#   {PUBLIC_URL}/api/auth/microsoft/callback
PUBLIC_URL=http://localhost

# Port for the frontend (nginx). Default 80.
# Change if 80 is taken: FRONTEND_PORT=8080
FRONTEND_PORT=80

# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=migrationops
DB_PASSWORD=change-me-strong-password
DB_NAME=migrationops

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a random string: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-64-char-secret

# ── Microsoft Azure AD login (optional) ──────────────────────────────────────
# Register an app at https://portal.azure.com → Azure AD → App registrations
# Redirect URI to register (Web type):  {PUBLIC_URL}/api/auth/microsoft/callback
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# ── Jira live sync (optional) ─────────────────────────────────────────────────
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@yourcompany.com
JIRA_API_TOKEN=
JIRA_JQL=project in (PROJ1, PROJ2) ORDER BY updated DESC
SYNC_CRON=0 */6 * * *

# ── Email reminders for Action Items (optional) ───────────────────────────────
# Leave SMTP_HOST blank to disable email sending entirely.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=CloudFuze Migration Ops <no-reply@yourdomain.com>
ACTION_ITEM_REMINDER_CRON=0 8 * * *
